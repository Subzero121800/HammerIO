<?xml version="1.0" encoding="UTF-8"?>
<mime-info xmlns="http://www.freedesktop.org/standards/shared-mime-info">
  <mime-type type="application/x-hammerio">
    <comment>HammerIO compressed archive</comment>
    <comment xml:lang="en">HammerIO compressed archive</comment>
    <glob pattern="*.hammer"/>
    <magic priority="60">
      <match type="string" offset="0" value="HMIO"/>
    </magic>
    <icon name="application-x-hammerio"/>
  </mime-type>
</mime-info>
